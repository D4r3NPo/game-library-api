@using GameLibrary.Shared.DTOs
@using GameLibrary.Shared.Enums

<li @key="Game.Id">
    <span>@Game.Title</span>
    <span>@Game.Status</span>
    <span>@Game.Rating</span>
    <div id="platforms">
        <PlatformCheckbox Platform="@GamePlatform.MacOS" SelectedPlatforms="@Game.Platforms.ToList()" />
        <PlatformCheckbox Platform="@GamePlatform.Windows" SelectedPlatforms="@Game.Platforms.ToList()" />
        <PlatformCheckbox Platform="@GamePlatform.Linux" SelectedPlatforms="@Game.Platforms.ToList()" />
        <PlatformCheckbox Platform="@GamePlatform.iOS" SelectedPlatforms="@Game.Platforms.ToList()" />
        <PlatformCheckbox Platform="@GamePlatform.Android" SelectedPlatforms="@Game.Platforms.ToList()" />
    </div>
    <div style="width: 100%;">
        <button class="edit" @onclick="EditAction">
            <svg xmlns="http://www.w3.org/2000/svg" height="24px" viewBox="0 -960 960 960" width="24px">
                <path
                d="M160-120q-17 0-28.5-11.5T120-160v-97q0-16 6-30.5t17-25.5l505-504q12-11 26.5-17t30.5-6q16 0 31 6t26 18l55 56q12 11 17.5 26t5.5 30q0 16-5.5 30.5T817-647L313-143q-11 11-25.5 17t-30.5 6h-97Zm544-528 56-56-56-56-56 56 56 56Z" />
            </svg>
        </button>
        <button class="delete" @onclick="DeleteAction">
            <svg xmlns="http://www.w3.org/2000/svg" height="24px" viewBox="0 -960 960 960" width="24px">
                <path
                d="M280-120q-33 0-56.5-23.5T200-200v-520q-17 0-28.5-11.5T160-760q0-17 11.5-28.5T200-800h160q0-17 11.5-28.5T400-840h160q17 0 28.5 11.5T600-800h160q17 0 28.5 11.5T800-760q0 17-11.5 28.5T760-720v520q0 33-23.5 56.5T680-120H280Zm148.5-171.5Q440-303 440-320v-280q0-17-11.5-28.5T400-640q-17 0-28.5 11.5T360-600v280q0 17 11.5 28.5T400-280q17 0 28.5-11.5Zm160 0Q600-303 600-320v-280q0-17-11.5-28.5T560-640q-17 0-28.5 11.5T520-600v280q0 17 11.5 28.5T560-280q17 0 28.5-11.5Z" />
            </svg>
        </button>
    </div>
</li>

@code {
    [Parameter] public required GameResponse Game { get; set; }

    [Parameter] public required EventCallback DeleteAction { get; set; }

    [Parameter] public required EventCallback EditAction { get; set; }
}
