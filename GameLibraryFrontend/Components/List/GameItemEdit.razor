@using GameLibrary.Shared.DTOs
@using GameLibrary.Shared.Enums

<li>
    <EditForm style="height: 3rem; width: 100%;" Model="Model">
        <DataAnnotationsValidator />
        <ValidationSummary />
        <div id="inputs">
            <InputText @bind-Value="Model.Title" placeholder="title"
                       style="width: calc(100% - 2rem); margin: 0.5rem; padding: 0.5rem; border-radius: 0.5rem; border: none;" />
            <InputSelect @bind-Value="Model.Status"
                         style="width: calc(100%); height: calc(100% - 1.25rem); border-radius: 0.5rem; border: none;">
                @foreach (var status in Enum.GetValues<GameStatus>())
                {
                    <option value="@status">@status</option>
                }
            </InputSelect>
            <InputNumber @bind-Value="Model.Rating" placeholder="rating"
                         style="width: calc(100% - 2rem); margin: 0.5rem; padding: 0.5rem; border-radius: 0.5rem; border: none;" />
            <div id="platforms" style="width: 100%;">
                <PlatformCheckbox Platform="@GamePlatform.MacOS" SelectedPlatforms="@SelectedPlatforms" />
                <PlatformCheckbox Platform="@GamePlatform.Windows" SelectedPlatforms="@SelectedPlatforms" />
                <PlatformCheckbox Platform="@GamePlatform.Linux" SelectedPlatforms="@SelectedPlatforms" />
                <PlatformCheckbox Platform="@GamePlatform.iOS" SelectedPlatforms="@SelectedPlatforms" />
                <PlatformCheckbox Platform="@GamePlatform.Android" SelectedPlatforms="@SelectedPlatforms" />
            </div>
            <div style="width: 100%;">
                <button class="validate" type="button" @onclick="ValidateAction">
                    <svg xmlns="http://www.w3.org/2000/svg" height="24px" viewBox="0 -960 960 960" width="24px">
                        <path
                        d="m424-408-86-86q-11-11-28-11t-28 11q-11 11-11 28t11 28l114 114q12 12 28 12t28-12l226-226q11-11 11-28t-11-28q-11-11-28-11t-28 11L424-408Zm56 328q-83 0-156-31.5T197-197q-54-54-85.5-127T80-480q0-83 31.5-156T197-763q54-54 127-85.5T480-880q83 0 156 31.5T763-763q54 54 85.5 127T880-480q0 83-31.5 156T763-197q-54 54-127 85.5T480-80Z" />
                    </svg>
                </button>
                <button class="cancel" type="button" @onclick="CancelAction">
                    <svg xmlns="http://www.w3.org/2000/svg" height="24px" viewBox="0 -960 960 960" width="24px" fill="#FFFFFF">
                        <path
                        d="m480-424 116 116q11 11 28 11t28-11q11-11 11-28t-11-28L536-480l116-116q11-11 11-28t-11-28q-11-11-28-11t-28 11L480-536 364-652q-11-11-28-11t-28 11q-11 11-11 28t11 28l116 116-116 116q-11 11-11 28t11 28q11 11 28 11t28-11l116-116Zm0 344q-83 0-156-31.5T197-197q-54-54-85.5-127T80-480q0-83 31.5-156T197-763q54-54 127-85.5T480-880q83 0 156 31.5T763-763q54 54 85.5 127T880-480q0 83-31.5 156T763-197q-54 54-127 85.5T480-80Z" />
                    </svg>
                </button>
            </div>
        </div>
    </EditForm>
</li>

@code {

    [Parameter] public required UpdateGameRequest Model { get; set; }
    [Parameter] public required List<GamePlatform> SelectedPlatforms { get; set; }
    [Parameter] public required EventCallback ValidateAction { get; set; }
    [Parameter] public required EventCallback CancelAction { get; set; }
}
